# Supabase Postgres - via connection pooler (para o app/Prisma Client)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta (para migrations do Prisma)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres"

# Supabase API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<publishable-key>"
SUPABASE_LEGACY_JWT_SECRET="<legacy-jwt-secret>"

# Service role key (admin) - usada apenas em server actions para criar usuários já confirmados.
# NUNCA exponha com prefixo NEXT_PUBLIC_ nem no cliente.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
